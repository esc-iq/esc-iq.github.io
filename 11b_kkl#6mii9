<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ESC.</title>
<link rel="icon" href="media/favicon.png" type="image/png">

<!-- ✅ ربط خط Baloo Bhaijaan 2 من Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Baloo+Bhaijaan+2:wght@400;700&display=swap" rel="stylesheet">

<style>
    /* ✅ إعداد الخط العام والاتجاه */
    body {
        font-family: 'Baloo Bhaijaan 2', sans-serif;
        background-color: #FAF9F6;
        margin: 0;
        padding: 0;
        color: #fff;
        direction: rtl;
        text-align: right;
    }

    /* شريط التنقل */
    #bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 30px;
        background-color: #0047AB;
        flex-wrap: wrap;
    }

    #bar .logo {
        font-size: 35px;
        font-weight: bold;
        color: #FAF9F6;
    }

    #bar nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    #bar nav a {
        color: #FAF9F6;
        text-decoration: none;
        font-weight: bold;
        padding: 8px 12px;
        border-radius: 5px;
        transition: background-color 0.3s;
    }

    #bar nav a:hover {
        background-color: rgba(255,255,255,0.2);
    }

    /* التنبيه */
    #alert {
        text-align: center;
        background-color: #0047AB;
        width: 450px;
        margin: 40px auto 0 auto;
        border-radius: 30px;
        padding: 10px;
        font-size: 25px;
    }

    /* العمود الرئيسي */
    #firstcolumn {
        text-align: center;
        background-color: #008080;
        width: auto;
        padding: 40px 20px;
        margin: 60px auto 0 auto;
        border-radius: 0;
    }

    #firstcolumn h2 {
        font-size: 25px;
        margin-bottom: 30px;
        color: #FAF9F6;
    }

    #firstcolumn p {
        font-size: 18px;
        color: #FAF9F6;
        line-height: 1.8;
        margin: 10px auto;
        width: 80%;
    }

    /* صور الفريق */
    .image-container {
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .image-box {
        text-align: center;
    }

    .image-box img {
        width: 300px;
        height: 300px;
        object-fit: cover;
        border-radius: 10px;
        transition: transform 0.3s;
    }

    .image-box img:hover {
        transform: scale(1.05);
    }

    .image-box .name {
        margin-top: 10px;
        font-size: 18px;
        font-weight: bold;
        color: #FAF9F6;
    }

    .image-box .info {
        font-size: 16px;
        color: #FAF9F6;
    }

    /* ✅ استجابة الشاشات الصغيرة */
    @media (max-width: 768px) {
        #bar {
            flex-direction: column;
            align-items: center;
        }

        #bar nav {
            gap: 10px;
            margin-top: 10px;
        }

        .image-box img {
            width: 90%;
            height: auto;
        }

        #alert {
            width: 90%;
            font-size: 20px;
        }

        #firstcolumn p {
            width: 95%;
        }
    }
</style>
</head>
